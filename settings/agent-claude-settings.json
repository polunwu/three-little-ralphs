{
  "permissions": {
    "deny": [
      "Read(/.env)",
      "Read(/**/.env)",
      "Read(~/.env)",
      "Read(./.env)",
      "Read(.env)",
      "Read(.env.*)",
      "Write(/.env)",
      "Write(/**/.env)",
      "Write(~/.env)",
      "Write(./.env)",
      "Write(.env)",
      "Write(.env.*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Write(*.production.*)",
      "Write(*.prod.*)"
    ]
  }
}
